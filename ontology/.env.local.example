DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[SERVICE_ROLE_KEY]

# 인증 이메일 링크(가입 확인/비밀번호 재설정)의 절대 URL 기준.
# 미설정 시 요청 origin 을 사용한다. 배포 시 실제 도메인으로 지정.
# Supabase 대시보드의 Redirect Allow List 에도 동일 도메인(/**)을 등록해야 한다.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# E2E 인증 여정 테스트용(선택) — 확인 완료된 시드 계정
# E2E_TEST_EMAIL=
# E2E_TEST_PASSWORD=

# ─── Neo4j (운영 그래프 / 반영본) ──────────────────────────────
# 앱의 "반영본" 그래프. 로컬은 Neo4j Desktop 2 인스턴스(권장) 또는 Docker(neo4j:5.26).
# 연결은 아래 3개 값만으로 결정된다(getNeo4jDriver). Bolt 기본 포트 7687.
# 배포 절차/트러블슈팅: docs/runbooks/neo4j-desktop-connection.md
# ⚠️ Windows: localhost 는 IPv6(::1)로 풀려 실패할 수 있어 127.0.0.1 명시 권장.
# Desktop 인스턴스는 카드의 Connection URI(예: neo4j://127.0.0.1:7687)를 그대로 사용.
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USERNAME=neo4j
# Neo4j Desktop 인스턴스 생성 시 설정한 비밀번호(최소 8자).
NEO4J_PASSWORD=[NEO4J_PASSWORD]
# 현재 드라이버 세션은 기본 DB(neo4j)를 사용한다(이 값은 참고용, 미사용).
NEO4J_DATABASE=neo4j
